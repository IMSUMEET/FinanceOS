# Copy this file to `.env.local` and fill in values for your environment.
# All vars are read at build time by Vite (must start with VITE_).

# Base URL of the FinanceOS backend. When empty, the frontend runs in mock
# mode and serves seeded data from `src/data/mockTransactions.js`.
VITE_API_BASE_URL=

# Force mock mode even if VITE_API_BASE_URL is set. Useful for design QA.
# Accepted values: "true" | "false"
VITE_USE_MOCK=true
